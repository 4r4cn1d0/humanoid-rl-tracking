# Virtual environments
venv/
venv_py311/
.venv/

# Python cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Large binary artifacts — exclude by default
*.zip
*.npz
*.mp4

# Checkpoints — too large for git
checkpoints/

# Tensorboard logs
tensorboard/

# OS / editor
.DS_Store
.idea/
.vscode/

# Keep all outputs EXCEPT raw timeseries npz (too large)
outputs/**/*.npz

# Keep everything else in outputs (plots, gifs, json, md, csv)
!outputs/
!outputs/**/*.png
!outputs/**/*.gif
!outputs/**/*.json
!outputs/**/*.md
!outputs/**/*.csv
